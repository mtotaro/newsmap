# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Drizzle — use Supabase Transaction pooler URL (port 6543)
DATABASE_URL=postgresql://postgres.<project-id>:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Inngest (leave empty in dev — Inngest Dev Server auto-detects)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=Ax...

# --- Phase 3 only ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@newsmap.app
